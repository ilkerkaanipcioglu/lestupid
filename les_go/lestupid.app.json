  },
  "trust_credentials": {
    "ready": true,
    "issuer": "les-certification",
    "disclosure_default": "summary_badge",
    "identity_policy": "pairwise_pseudonymous_by_default",
    "web3_policy": "optional_hash_only_revocable",
    "domains": [
