{
  "schema_version": "lestupid.app_manifest.v1",
  "product_id": "les-go",
  "name": "LesTupid Go",
  "service": "les_go",
  "version": "0.1.0",
  "status": "internal_candidate",
  "directory": "les_go",
  "summary": "Mobile web/PWA shell for contextual place and mode check-ins, app activation, channel consent, and cross-app LesTupid opportunities.",
  "ecosystem_roles": [
    "activation_shell",
    "student_checkin",
    "contextual_checkin",
    "place_mode_flow",
    "contextual_ui_system",
    "semantic_tempo_design",
    "place_soul_layout",
    "density_aware_feed",
    "risk_honesty_ui",
    "visual_demo_gallery",
    "cross_app_storyboard",
    "travel_readiness_preview",
    "safe_trip_flow",
    "student_launch_board",
    "university_viral_loop",
    "graduate_pathway_preview",
    "nearby_place_discovery",
    "attention_limited_topics",
    "place_utility_launcher",
    "aggregate_next_stop_flow",
    "micro_gig_preview",
    "creator_promotion_preview",
    "live_content_gig_preview",
    "living_cv_profile",
    "student_application_launcher",
    "education_opportunity_preview",
    "opportunity_feed",
    "manifest_launcher",
    "pwa_shell"
  ],
  "identity_activation": {
    "model": "shared_lestupid_identity",
    "registration": "handled_by_lestupid_identity_layer",
    "app_activation_required": false,
    "activation_product_id": "les-go",
    "activation_permissions": [
      "app_activation_center",
      "channel_activation_center",
      "place_checkin",
      "place_mode_selection",
      "nearby_place_preview",
      "nearby_topic_preview",
      "opportunity_preview",
      "place_menu_preview",
      "third_party_ticket_link_preview",
      "route_link_preview",
      "aggregate_next_stop_preview",
      "service_gig_preview",
      "creator_promotion_preview",
      "live_content_gig_preview",
      "living_cv_profile",
      "cv_signal_preview",
      "application_launcher",
      "education_opportunity_preview",
      "pseudonymous_trust_badge_preview",
      "selective_trust_disclosure",
      "safe_contact_preview",
      "student_launch_preview",
      "graduate_pathway_preview",
      "trusted_proximity_preview",
      "private_relationship_event_preview",
      "contact_place_graph_preview",
      "affiliate_game_card_preview",
      "quest_deck_preview",
      "adult_venue_safety_mode",
      "local_listing_preview"
    ],
    "user_controls": [
      "activate",
      "pause",
      "revoke",
      "export"
    ]
  },
  "runtime_modes": [
    "standalone_app",
    "ecosystem_activated_app"
  ],
  "portability": {
    "standalone_ready": true,
    "ecosystem_activation_optional": true,
    "extraction_difficulty": "low",
    "data_owner": "app",
    "required_adapters": [],
    "optional_adapters": [
      "identity_adapter",
      "activation_adapter",
      "channel_adapter",
      "match_opportunity_adapter",
      "certification_adapter",
      "loyalty_adapter",
      "les_block_adapter",
      "ai_adapter",
      "contacts_adapter"
    ],
    "export_required": true,
    "separation_rule": "LesTupid Go is a PWA shell and opportunity launcher; each source app keeps its own runtime, data, and business logic."
  },
  "platform_strategy": {
    "delivery_model": "simple_fast_flexible_pwa_first",
    "mobile_web": "responsive_pwa_first",
    "mobile_app": "after_loop_proves_useful",
    "desktop_app": "web_pwa_first",
    "backend": "none_in_v1",
    "runtime_config": ".env",
    "opportunity_adapter_modes": [
      "mock",
      "http"
    ],
    "ui_principles": "les_go/contextual-ui-principles.md",
    "semantic_ui_rule": "fast things feel fast, flowing things flow, static things stand still, crowded contexts feel dense, calm contexts breathe, risky contexts look risky, and each app keeps its own mood",
    "visual_demo_flows": "docs/VISUAL_DEMO_FLOWS.md"
  },
  "integrations": {
    "les_wait": {
      "ready": true,
      "optional": true,
      "use_cases": [
        "queue-safe actions",
        "waiting status opportunities",
        "qr queue join",
        "table or sign code queue join",
        "phone number queue join",
        "proximity place discovery",
        "venue owner enabled queue",
